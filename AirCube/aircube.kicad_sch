	)
	(text "This is a connector for an optional \nbattery module. The sensor module \nshould not contain any battery logic \nin order to make it indepdent of any \nspecific battery technology.\n\nThe 0 Ohm resistor is used as a bypass \nif this connector is not used and should \nbe desoldered / DNP if a battery module is \nused."
		(exclude_from_sim no)
		(at 347.218 85.344 0)
		(effects
			(font
				(size 1.27 1.27)
			)
			(justify left)
		)
		(uuid "1a96908d-316c-4a59-ad5c-a4ba689d3dac")
	)
	(text "Recommended I2C pullup \nresistors at bus master."
		(exclude_from_sim no)
		(at 229.87 77.216 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "2b12aca3-0dfc-4962-bbf2-3f511e60800b")
	)
	(text "WS2812 and similar RGB LEDs have a logic level\nof 0.7x for HIGH and 0.3x for LOW, requiring a level\nshifter for correct 3V3 communication."
		(exclude_from_sim no)
		(at 186.69 115.57 0)
		(effects
			(font
				(size 1.27 1.27)
			)
		)
		(uuid "59480d43-9e7a-41ec-83eb-83614e13e218")
	)
	(text "Keep this section far \naway from any heat emitting \ncomponents. Ideally on its \nown island."
		(exclude_from_sim no)
		(at 19.558 132.588 0)
		(effects
			(font
				(size 1.27 1.27)
			)
